rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userCreateFields() {
      return [
        'uid',
        'email',
        'displayName',
        'photoURL',
        'totalPoints',
        'triviaPoints',
        'triviaStreak',
        'triviaBestStreak',
        'triviaAnswered',
        'createdAt',
        'updatedAt',
        'country',
        'province',
        'city',
        'privateGroups',
        'isActive'
      ];
    }

    function userEditableFields() {
      return ['country', 'province', 'city', 'updatedAt', 'photoURL', 'displayName'];
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(userCreateFields())
        && request.resource.data.uid == userId
        && request.resource.data.totalPoints == 0
        && (!('isActive' in request.resource.data) || request.resource.data.isActive == true)
        && (!('privateGroups' in request.resource.data) || request.resource.data.privateGroups == [])
        && (!('triviaPoints' in request.resource.data) || request.resource.data.triviaPoints == 0)
        && (!('triviaStreak' in request.resource.data) || request.resource.data.triviaStreak == 0)
        && (!('triviaBestStreak' in request.resource.data) || request.resource.data.triviaBestStreak == 0)
        && (!('triviaAnswered' in request.resource.data) || request.resource.data.triviaAnswered == 0);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userEditableFields());
      allow delete: if false;
    }

    match /user_tokens/{userId} {
      allow read: if false;
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['token', 'platform', 'updatedAt']);
      allow delete: if isOwner(userId);
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /predictions/{predictionId} {
      allow read: if signedIn() && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    match /leagues/{leagueId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /groups/{groupId} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow write: if false;
    }

    match /trivia_questions/{questionId} {
      allow read: if signedIn() && !resource.data.keys().hasAny(['correctAnswer']);
      allow write: if false;
    }

    match /trivia_answers/{answerId} {
      allow read: if signedIn() && request.auth.uid == resource.data.userId;
      allow write: if false;
    }
  }
}
